{
  "port": 8888,
  "homeserverUrl": "http://your-matrix-server:8008",
  "accessToken": "replace-me-matrix-access-token",
  "adminUserIds": ["@admin:your-server"],
  "managementRoomId": "!yourManagementRoomId:your-server",
  "agentApiToken": "replace-me-agent-token",
  "projects": {
    "your-project": {
      "roomId": "!yourRoomId:your-server"
    },
    "operator": {
      "roomId": "!yourOtherRoomId:your-server",
      "agent": "opencode",
      "model": "opencode/minimax-m2.5-free",
      "command": ["opencode", "run"],
      "commandPrefix": "!op",
      "allowedCliCommands": ["usage", "stats", "models", "model", "help"],
      "commandTimeoutSeconds": 30,
      "timeoutSeconds": 300,
      "heartbeatSeconds": 45,
      "verbosity": "output",
      "senderAllowlist": ["@admin:your-server"],
      "progressUpdates": true,
      "stateDir": ".operator-state",
      "projectWorkingDirectory": "/abs/path/to/project",
      "ackTemplate": "Received. Starting OpenCode job {{job_id}}.",
      "progressTemplate": "OpenCode {{phase}} (job {{job_id}}).",
      "contextTailLines": 60
    }
  }
}
